# AI API Key - Obtén una gratis en https://openrouter.ai/keys
# Sin tarjeta de crédito, usas Gemini 2.5 Flash y otros modelos gratis
AI_API_KEY=tu_api_key_de_openrouter_aqui

# (Opcional) URL base de la API - Por defecto usa OpenRouter
# AI_BASE_URL=https://openrouter.ai/api/v1

# (Opcional) Modelo a usar - Por defecto usa Gemini 2.5 Flash
# AI_MODEL=google/gemini-2.5-flash

# (Opcional) URL de tu app para identificación en OpenRouter
# APP_URL=https://insightpdf.vercel.app
