# 🆓 PROVEEDOR PRINCIPAL: OpenRouter (28+ modelos gratis, 50 req/día sin tarjeta)
# Regístrate gratis en https://openrouter.ai/keys (NO necesita tarjeta de crédito)
OPENROUTER_API_KEY=sk-or-v1-tu_api_key_aqui

# 🆓 PROVEEDOR SECUNDARIO: Groq (respaldo automático, ~1000 req/día gratis)
# La app usa Groq cuando OpenRouter se queda sin cuota
# Regístrate gratis en https://console.groq.com/keys (NO necesita tarjeta)
# GROQ_API_KEY=gsk_tu_api_key_groq_aqui

# (Opcional) URL de tu app para identificación en OpenRouter
# APP_URL=https://insightpdf.vercel.app

# (Opcional) Modelo por defecto en OpenRouter
# AI_MODEL=google/gemini-2.5-flash:free
